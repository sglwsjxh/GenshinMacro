<Window x:Class="GenshinMacro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:GenshinMacro.ViewModels"
        mc:Ignorable="d"
        Title="Genshin Macro"
        Width="360"
        Height="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="{StaticResource FontFamily}">

    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,8,0,12">
            <TextBlock Text="Genshin Macro"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="宏控制面板"
                       FontSize="14"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="{StaticResource CardBrush}"
                CornerRadius="12"
                Padding="20"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#18000000" BlurRadius="16" ShadowDepth="2" Opacity="0.4"/>
            </Border.Effect>

            <StackPanel>
                <Border HorizontalAlignment="Center"
                        CornerRadius="999"
                        Padding="12,6"
                        Margin="0,0,0,2">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#F3F4F6"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                    <Setter Property="Background" Value="#EAF7ED"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource TextSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Rectangle Height="1"
                           Fill="{StaticResource BorderBrush}"
                           Margin="0,0,0,12"/>

                <Border Background="#F0FDF9"
                        CornerRadius="10"
                        Padding="14,12"
                        Margin="0,0,0,10"
                        BorderBrush="#D7EFE7"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="38"
                                 Height="38"
                                 Background="{StaticResource AccentBrush}"
                                 CornerRadius="10"
                                 Grid.Column="0"
                                 Margin="0,0,14,0">
                             <Viewbox Width="20" Height="20">
                                 <Path Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"
                                       Fill="White" Stretch="Uniform"/>
                             </Viewbox>
                         </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="侧键1 — 持续旋转视角"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="按住 X1 侧键自动右转视角"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="#FFF5F5"
                        CornerRadius="10"
                        Padding="14,12"
                        BorderBrush="#F1D6D6"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                             <TextBlock Text="侧键2 — 双键连击"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}"/>
                             <TextBlock Text="按住 X2 侧键执行连击宏"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- Error Banner -->
        <Border Grid.Row="2" CornerRadius="8" Padding="12,8" Margin="0,8,0,0"
                BorderBrush="#FF9800" BorderThickness="1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#FFF3E0"/>
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowError}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding ErrorMessage}"
                           TextWrapping="Wrap" FontSize="12"
                           Foreground="#E65100" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="✕"
                        Command="{Binding DismissErrorCommand}"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#E65100" FontSize="14"
                        Padding="4,0" Margin="8,0,0,0"
                        Cursor="Hand" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Button Grid.Row="3"
                Command="{Binding ToggleCommand}"
                FontSize="18"
                FontWeight="SemiBold"
                Padding="44,14"
                Margin="0,20,0,0"
                HorizontalAlignment="Center"
                Cursor="Hand">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                    <Setter Property="Content" Value="启 动"/>
                    <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                            <Setter Property="Content" Value="停 止"/>
                            <Setter Property="Background" Value="{StaticResource ErrorBrush}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Window>
