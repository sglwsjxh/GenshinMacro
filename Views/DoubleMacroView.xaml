<UserControl x:Class="GenshinMacro.Views.DoubleMacroView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:GenshinMacro.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:DoubleMacroViewModel}"
             d:DesignHeight="400"
             d:DesignWidth="500"
             ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
             ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
             FontFamily="{StaticResource FontFamily}"
             Foreground="{DynamicResource TextFillColorPrimaryBrush}"
             mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="42,16,42,20">

            <!-- Page Header -->
            <TextBlock Text="双玛头宏"
                       Style="{StaticResource PageHeaderStyle}" />
            <TextBlock Text="配置双玛头连点宏参数"
                       Style="{StaticResource PageDescriptionStyle}" />

            <!-- 基本设置 Card -->
            <ui:CardExpander Margin="0,0,0,12"
                             ContentPadding="0"
                             Icon="{ui:SymbolIcon Keyboard24}">
                <ui:CardExpander.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Style="{StaticResource SettingLabelStyle}"
                                   Text="启用双玛头宏" />
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Style="{StaticResource SettingDescriptionStyle}"
                                   Text="开启后，按住触发键即可执行双玛头连击" />
                        <ui:ToggleSwitch Grid.Row="0" Grid.RowSpan="2"
                                         Grid.Column="1"
                                         Margin="0,0,24,0"
                                         IsChecked="{Binding Enabled}" />
                    </Grid>
                </ui:CardExpander.Header>

                <StackPanel>
                    <!-- Trigger Key -->
                    <Separator Margin="-18,0" BorderThickness="0,1,0,0" />
                    <Border Style="{StaticResource PropertyRowStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Style="{StaticResource SettingLabelStyle}"
                                       Text="触发按键" />
                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Style="{StaticResource SettingDescriptionStyle}"
                                       Text="选择触发双玛头宏的按键" />
                            <ComboBox Grid.Row="0" Grid.RowSpan="2"
                                      Grid.Column="1"
                                      MinWidth="120"
                                      Margin="0,0,36,0"
                                      ItemsSource="{Binding AvailableKeys}"
                                      SelectedItem="{Binding TriggerKey}" />
                        </Grid>
                    </Border>
                </StackPanel>
            </ui:CardExpander>

            <!-- 提示信息 -->
            <ui:CardControl Margin="0,0,0,12"
                            Icon="{ui:SymbolIcon Info24}">
                <ui:CardControl.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Style="{StaticResource SettingLabelStyle}"
                                   Text="提示" />
                        <TextBlock Grid.Row="1"
                                   Style="{StaticResource SettingDescriptionStyle}"
                                   Text="修改配置后，下次启动宏时生效。按住触发键即可连续执行双玛头连击。" />
                    </Grid>
                </ui:CardControl.Header>
            </ui:CardControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
