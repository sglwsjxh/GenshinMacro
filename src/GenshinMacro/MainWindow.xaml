<Window x:Class="GenshinMacro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Genshin Macro"
        Width="360"
        Height="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}"
        KeyDown="OnKeyDown">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Section -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,20,0,8">
            <TextBlock Text="Genshin Macro"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="宏控制面板"
                       FontSize="14"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Card Section -->
        <Border Grid.Row="1"
                Background="{StaticResource CardBrush}"
                CornerRadius="10"
                Padding="20"
                Margin="0,16,0,0">
            <Border.Effect>
                <DropShadowEffect Color="#1A000000" BlurRadius="12" ShadowDepth="1" Opacity="0.5"/>
            </Border.Effect>
            <StackPanel>
                <!-- Mode 1 -->
                <Border Background="#F0FDF9"
                        CornerRadius="8"
                        Padding="14,12"
                        Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Indicator -->
                        <Border Width="36" Height="36" Background="{StaticResource AccentBrush}" CornerRadius="8" Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="⟳" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <!-- Label -->
                        <TextBlock Grid.Column="1"
                                   Text="侧键1 → 持续旋转视角"
                                   FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Mode 2 -->
                <Border Background="#FFF5F5"
                        CornerRadius="8"
                        Padding="14,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Indicator -->
                        <Border Width="36" Height="36" Background="#E53935" CornerRadius="8" Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="⚡" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <!-- Label -->
                        <TextBlock Grid.Column="1"
                                   Text="侧键2 → 双键连击"
                                   FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- Start Button -->
        <Button Grid.Row="2"
                Content="启 动"
                Style="{StaticResource PrimaryButton}"
                FontSize="18"
                Padding="40,12"
                Margin="0,24,0,0"
                HorizontalAlignment="Center"/>
    </Grid>
</Window>
